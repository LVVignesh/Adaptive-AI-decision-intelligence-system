# Python
__pycache__/
*.pyc
*.pyo
.env

# Virtual environment
.venv/

# ChromaDB local vector store (generated at runtime)
chroma_db/

# Training logs & outputs (generated at runtime)
logs/*
!logs/expert_trajectories.jsonl

# VS Code
.vscode/

# Zip deployment packages
*.zip

# Scratch / debug scripts
scratch/

# Training checkpoints (large binary files)
outputs/*/checkpoint-*/

# Large model binary files (use HuggingFace Hub to store these)
*.safetensors
*.pt
*.pth
*.bin
